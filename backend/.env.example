# ===== LLM API キー =====
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...
LLM_MODEL=gpt  # gpt または gemini

# ===== Database =====
DATABASE_URL=sqlite:///./ad_insight.db
# 本番環境: DATABASE_URL=postgresql://user:password@host:5432/ad_insight_spec

# ===== Application Settings =====
DEBUG=False
LOG_LEVEL=INFO
API_TIMEOUT_SECONDS=60
API_RATE_LIMIT=100

# ===== Optional =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
